{
  "name": "server",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "cross-env NODE_ENV=test tsx --test \"src/__tests__/**/*.test.ts\""
  },
  "dependencies": {
    "@ai-sdk/google": "catalog:",
    "@trpc/server": "catalog:",
    "@turborepo-boilerplate/api": "workspace:*",
    "@turborepo-boilerplate/auth": "workspace:*",
    "@turborepo-boilerplate/cache": "workspace:*",
    "@turborepo-boilerplate/db": "workspace:*",
    "@turborepo-boilerplate/env": "workspace:*",
    "@turborepo-boilerplate/services": "workspace:*",
    "ai": "catalog:",
    "better-auth": "catalog:",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "catalog:",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "swagger-ui-express": "^5.0.1",
    "trpc-to-openapi": "^3.1.0",
    "uuid": "^13.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "cross-env": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsdown": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
